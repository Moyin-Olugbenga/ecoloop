generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SELLER
  MIDDLEMAN
  BUYER
  SCHOOL
  ADMIN
}

enum ListingStatus {
  LISTED
  CLAIMED
  SOLD
}

enum WasteType {
  PLASTIC
  METAL
  ORGANIC
  EWASTE
  PAPER
  GLASS
  OTHER
}

enum TokenType {
  ACTIVATION
  PASSWORD_RESET
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  role          Role
  lga           String?
  phone         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  reviewsGiven      Review[]      @relation("BuyerReviews")
  reviewsReceived   Review[]      @relation("SellerReviews")
  listings          Listing[]      @relation("SellerListings")
  claims            Listing[]      @relation("MiddlemanClaims")
  purchases         Order[]        @relation("BuyerOrders")
  uploadedTutorials Tutorial[]     @relation("UploadedTutorials")
  watchedTutorials  TutorialView[] @relation("WatchedTutorials")
  tokens            VerificationToken[]  
  notifications     Notification[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  dumpSiteId String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model VerificationToken {
  id        String    @id @default(uuid())
  token     String    @unique
  type      TokenType
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, type])
}

model DumpSite {
  id             String          @id @default(uuid())
  name           String
  lat            Float
  lng            Float  
  lga            String?
  pollutionScore Int             @default(0) // 0-100, updated by simulated readings
  readings       SensorReading[]
  listings       Listing[]
  createdAt      DateTime        @default(now())
  updatedAt DateTime  @updatedAt
}

model SensorReading {
  id        String   @id @default(uuid())
  siteId    String
  site      DumpSite @relation(fields: [siteId], references: [id])
  score     Int
  createdAt DateTime @default(now())
  updatedAt DateTime  @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      // Enforced on the frontend/actions layer from 1 to 5
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationship Links
  buyerId   String
  buyer     User     @relation("BuyerReviews", fields: [buyerId], references: [id], onDelete: Cascade)

  sellerId  String
  seller    User     @relation("SellerReviews", fields: [sellerId], references: [id], onDelete: Cascade)

  // 🛡️ ANTI-THEFT GUARDIAN: Ensures one comprehensive verified evaluation per buyer/seller pairing
  @@unique([buyerId, sellerId])
}

model Listing {
  id         String        @id @default(uuid())
  sellerId   String
  seller     User          @relation("SellerListings", fields: [sellerId], references: [id])
  wasteType  WasteType
  quantityKg Float
  price      Float?
  imageUrl   String?
  location   String?       
  status     ListingStatus @default(LISTED)

  dumpSiteId String?
  dumpSite   DumpSite?     @relation(fields: [dumpSiteId], references: [id])

  middlemanId String?
  middleman   User?        @relation("MiddlemanClaims", fields: [middlemanId], references: [id])

  // when a middleman relists a sorted batch, link back to source listings
  sourceListingId String?
  sourceListing   Listing?  @relation("BatchSource", fields: [sourceListingId], references: [id])
  batchItems      Listing[] @relation("BatchSource")

  order     Order?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Order {
  id        String   @id @default(uuid())
  listingId String   @unique
  listing   Listing  @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User     @relation("BuyerOrders", fields: [buyerId], references: [id])
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime  @updatedAt
}

model Tutorial {
  id           String         @id @default(uuid())
  title        String
  description  String
  videoUrl     String
  thumbnailUrl String?
  category     WasteType?
  uploadedById String
  uploadedBy   User           @relation("UploadedTutorials", fields: [uploadedById], references: [id])
  views        TutorialView[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model TutorialView {
  id         String   @id @default(uuid())
  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id])
  userId     String
  user       User     @relation("WatchedTutorials", fields: [userId], references: [id])
  watchedAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tutorialId, userId])
}
